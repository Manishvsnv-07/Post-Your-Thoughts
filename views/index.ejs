<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>posts</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="output.css">
</head>

<body>
    <div class="cont gap-2 relative text-white w-full bg-zinc-900 h-screen flex flex-col justify-center items-center">
        <img class="w-[4vw] absolute left-0 top-0 ml-2 mt-2 rounded-[50%] " src="imgs/logo.png" alt="">
        <form action="/login" method="post">
            <div
                class="upper text-black rounded-xl w-[80vw] sm:w-[40vw] gap-3 bg-white border outline-none flex flex-col justify-center items-center border-white h-[45vh]">
                <h1 class="text-xl">Login 👇</h1>
                <input type="text" class="rounded-md w-60 bg-transparent border border-black px-2 py-2"
                    placeholder="Enter Your Username" name="username">
                <input class="rounded-md w-60  bg-transparent border border-black px-2 py-2" type="password"
                    placeholder="Enter Your Password" name="password">
                <button type="login"
                    class="rounded-md bg-yellow-300 text-black w-16 hover:cursor-pointer hover:scale-[1.1]">Login</button>
            </div>
        </form>
        <form action="/create" method="post">
            <div
                class="lower border-white rounded-xl w-[80vw] sm:w-[40vw] gap-3 bg-transparent border outline-none flex flex-col justify-center items-center h-[50vh]">

                <h1 class="text-xl">Create an account 🥳</h1>
                <input type="text" class="rounded-md w-60 bg-transparent border border-white px-2 py-2"
                    placeholder="Enter Your Name" name="name">
                <input type="text" class="rounded-md w-60 bg-transparent border border-white px-2 py-2"
                    placeholder="Create An Username" name="username">
                <input class="rounded-md w-60  bg-transparent border border-white px-2 py-2" type="password"
                    placeholder="Create Password" name="password">
                <button type="create"
                    class="rounded-md bg-yellow-300 text-black w-16 hover:cursor-pointer hover:scale-[1.1]">Create</button>
            </div>
        </form>
    </div>
</body>

</html>